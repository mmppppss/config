# Gruvbox Kitty Theme
# Personalizado para Hyprland

# Font con ligaduras
font_family Hack Nerd Font Mono
font_size 11
disable_ligatures no

# Transparência
background_opacity 0.85

# Cores Gruvbox Dark
foreground #ebdbb2
background #282828
selection_foreground #ebdbb2
selection_background #3c3836

# Cursor
cursor #fbf1c7
cursor_shape beam
cursor_blink_interval 0.5

# Colores
color0 #282828
color1 #cc241d
color2 #98971a
color3 #d79921
color4 #458588
color5 #b16286
color6 #689d6a
color7 #a89984
color8 #928374
color9 #fb4934
color10 #b8bb26
color11 #fabd2f
color12 #83a598
color13 #d3869b
color14 #8ec07c
color15 #fbf1c7

# Scrollback
scrollback_lines 10000

# Mouse
mouse_hide_wait 3

# Performance
repaint_delay 10
input_delay 3
sync_to_monitor yes

# Window
window_padding_width 5
window_border_width 1
window_margin_width 0

# Tab bar
tab_bar_edge top
tab_bar_style powerline
tab_title_template "{index}: {title}"
